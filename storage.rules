rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────────────────────
    // User-scoped files: avatars, resumes, project images, PDFs
    // Only the file owner can write; any authenticated user can read
    // (read access needed for public portfolio rendering).
    // ─────────────────────────────────────────────────────────────────────────
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   // Max 10 MB per file
                   && request.resource.size < 10 * 1024 * 1024
                   // Only allow images and PDFs
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Default deny — anything not matched above is rejected
    // ─────────────────────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
