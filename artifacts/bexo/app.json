{
  "expo": {
    "name": "Bexo",
    "slug": "bexo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bexo",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mybexo.app"
    },
    "android": {
      "backgroundColor": "#F7F5F0",
      "package": "com.mybexo.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#F7F5F0"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://mybexo.com"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "f3faad6f-afc2-4dcd-98e5-995657ff49e9"
      }
    }
  }
}
